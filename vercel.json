{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://demo.flyfish.group; frame-ancestors 'none'; base-uri 'self'; form-action 'none'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/zh",
      "destination": "/zh-CN/",
      "permanent": true
    },
    {
      "source": "/cn",
      "destination": "/zh-CN/",
      "permanent": true
    },
    {
      "source": "/en",
      "destination": "/en-US/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/zh-CN/:path*",
      "destination": "/zh-CN/index.html"
    },
    {
      "source": "/en-US/:path*",
      "destination": "/en-US/index.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
